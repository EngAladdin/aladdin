# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Cerebrum Ingestion Service Configuration
# Copy to .env and fill in real values. NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_QUEUE_KEY=cerebrum:events

# ── Security ───────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET=change-me-generate-a-32-byte-hex-secret

# Comma-separated IPs/CIDRs allowed to POST to the HTTP endpoint.
# Leave empty to allow all (dev only).
# Example: ALLOWED_IPS=10.0.0.5,10.0.1.0/24
ALLOWED_IPS=

# ── File-Tail Ingestor ─────────────────────────────────────────────────────────
LOG_FILE_PATH=/var/log/honeytrap/events.jsonl
TAIL_FROM_END=true
POLL_INTERVAL=0.5

# ── HTTP Ingestor ──────────────────────────────────────────────────────────────
PORT=8000
WORKERS=2
DOCS_ENABLED=false   # set true in dev to enable /docs

# ── Queue retry ────────────────────────────────────────────────────────────────
QUEUE_MAX_RETRIES=5
QUEUE_INITIAL_DELAY=0.5

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
